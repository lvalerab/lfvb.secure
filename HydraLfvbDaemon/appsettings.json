{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Conexiones": {
    "ws": {
      "url": "ws://localhost:5000/hydra",
      "reintento":10
    },
    "db": {
      "connectionString": "Server=localhost;Database=hydra;User Id=sa;Password=your_password;"
    },
    "sw": {
      "url": "http://localhost:5000/api/sw"
    }
  },
  "main": {
    "bucle": {
      "wait": 60000
    },
    "threads": {
      "max": 10
    }
  },
  "colas": {
    "local": {
      "jobs": {
        "items": {
          "max": 10,
          "exec": 3
        },
        "cpu": {
          "max": 0.7
        },
        "memory": {
          "max": 0.7
        }
      }
     },
    "priority": {
      "jobs": {
        "items": {
          "max": 10,
          "exec": 3
        },
        "cpu": {
          "max": 0.5
        },
        "memory": {
          "max": 0.7
        }
      }
    },
    "remote": {
      "jobs": {
        "items": {
          "max": 10,
          "exec": 3
        },
        "cpu": {
          "max": 0.3
        },
        "memory": {
          "max": 0.7
        }
      }
    }
  }
}
