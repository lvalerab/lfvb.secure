{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "main": {
    "bucle": {
      "wait": 1000
    },
    "threads": {
      "max": 100
    }
  },
  "colas": {
    "local": {
      "jobs": {
        "items": {
          "max": 10,
          "exec": 3
        },
        "cpu": {
          "max": 0.7
        },
        "memory": {
          "max": 0.7
        }
      }
     },
    "priority": {
      "jobs": {
        "items": {
          "max": 10,
          "exec": 3
        },
        "cpu": {
          "max": 0.5
        },
        "memory": {
          "max": 0.7
        }
      }
    },
    "remote": {
      "jobs": {
        "items": {
          "max": 10,
          "exec": 3
        },
        "cpu": {
          "max": 0.3
        },
        "memory": {
          "max": 0.7
        }
      }
    }
  }
}
